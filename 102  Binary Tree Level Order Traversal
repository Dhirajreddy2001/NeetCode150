
We are given an binary tree as input and we have to return output as List[list] where each list contains all the elements in a level of the binary tree;


Example :
             3     [3]
            /  \
          9    20  [9, 20]
              /  \
            15    7  [15, 7]

Input: root = [3,9,20,null,null,15,7]
Output: [[3],[9,20],[15,7]]

class Solution {
    List<List<Integer>> result = new ArrayList<>();
    public List<List<Integer>> levelOrder(TreeNode root) {
       
       if(root == null) return result;

       getLevelOrder(root, 0);
       return result;
        
    }

    public void getLevelOrder(TreeNode root, int level)
    {
        if(result.size() == level)
        {
            result.add(new ArrayList<Integer>());
        }

        result.get(level).add(root.val);

        if(root.left != null)
        {
            getLevelOrder(root.left, level+1);
        }
        if(root.right != null)
        {
            getLevelOrder(root.right, level + 1);
        }
    }
}
