addWord(word):

1. Start at root.

2. For each character ch:
   - If current node does not have ch, create a new TrieNode.
   - Move to that child node.

3. After the last character, mark current node as word = true.

search(word):

1. Start recursive search from root.

2. For each character ch:

   If ch is a normal letter:
   - Check if current node has that child.
   - If not, return false.
   - If yes, move to that child.

   If ch is '.':
   - Try every child of current node.
   - Recursively search the remaining substring from that child.
   - If any child returns true, return true.
   - If no child works, return false.

3. After all characters are processed:
   - Return true only if current node marks the end of a complete word.


class TrieNode {
    // Stores child nodes for each character
    Map<Character, TrieNode> children = new HashMap<>();

    // True if a complete word ends at this node
    boolean word = false;
}

class WordDictionary {
    // Root node of the trie
    TrieNode trie;

    public WordDictionary() {
        trie = new TrieNode();
    }
    
    public void addWord(String word) {
        // Start from the root
        TrieNode node = trie;

        // Insert each character one by one
        for (char ch : word.toCharArray()) {

            // If character path does not exist, create a new node
            if (!node.children.containsKey(ch)) {
                node.children.put(ch, new TrieNode());
            }

            // Move to the child node
            node = node.children.get(ch);
        }

        // Mark the last node as the end of a complete word
        node.word = true;
    }
    
    private boolean searchInTree(String word, TrieNode node) {

        // Traverse each character in the search word
        for (int i = 0; i < word.length(); i++) {
            char ch = word.charAt(i);

            // If character is '.', it can match any child character
            if (ch == '.') {

                // Try all possible children from current node
                for (TrieNode child : node.children.values()) {

                    // Search remaining part of word from this child
                    if (searchInTree(word.substring(i + 1), child)) {
                        return true;
                    }
                }

                // If no child matches, return false
                return false;
            }

            // For normal character, path must exist
            if (!node.children.containsKey(ch)) {
                return false;
            }

            // Move to the next character node
            node = node.children.get(ch);
        }

        // After all characters are matched,
        // return true only if this node marks a complete word
        return node.word;
    }
    
    public boolean search(String word) {
        // Start searching from root
        return searchInTree(word, trie);
    }
}
