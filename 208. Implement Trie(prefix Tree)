We are to create a special data structure tree.

for this we define an additional data structure called TrieNode that will help use to perform operations in the time of O(1);

Algorithm :
TrieNode:
1. Store links for 26 lowercase letters.
2. Store isEnd to know if a complete word ends here.

insert(word):
1. Start at root.
2. For each character:
   - If missing, create node.
   - Move to child.
3. Mark last node as end.

searchPrefix(word):
1. Start at root.
2. For each character:
   - If missing, return null.
   - Move to child.
3. Return last node.

search(word):
1. node = searchPrefix(word)
2. Return node != null && node.isEnd()

startsWith(prefix):
1. node = searchPrefix(prefix)
2. Return node != null


code: class TrieNode {

    private TrieNode[] links;
    private final int R = 26;
    private boolean isEnd;

    public TrieNode()
    {
        links = new TrieNode[26];
    }
    public boolean containsKey(char ch)
    {
        return links[ch - 'a'] != null;
    }
    public TrieNode get(char ch)
    {
        return links[ch - 'a'];
    }
    public void put(char ch, TrieNode node)
    {
        links[ch - 'a'] = node;
    }
    public void setEnd() { isEnd = true;}
    public boolean isEnd() { return isEnd;}
}
class Trie {

    TrieNode root;

    public Trie() {
        
        root = new TrieNode();
    }
    
    public void insert(String word) {
        
        TrieNode node = root;
        for(int i =0; i< word.length(); i++)
        {
            char curr_char = word.charAt(i);
            if(! node.containsKey(curr_char))
            {
                node.put(curr_char, new TrieNode());
            }

            node = node.get(curr_char);
        }
        node.setEnd();
      
    }
    public TrieNode searchPrefix(String word)
    {
        TrieNode node = root;
        for(int i =0; i< word.length(); i++)
        {
            char curr_char = word.charAt(i);

            if(node.containsKey(curr_char))
            {
                node = node.get(curr_char);
            }
            else return null;
        }

        return node;
    }
    public boolean search(String word) {
        
        TrieNode node = searchPrefix(word);
        return node!= null && node.isEnd();
    }
    
    public boolean startsWith(String prefix) {
        TrieNode node = searchPrefix(prefix);

        return node != null;
    }
}
