We are given an input string and this string unix file path we return its simplified path.

class Solution {
    public String simplifyPath(String path) {

        if(path.length() == 0) return "";

        Stack<String> stack = new Stack<>();

        String[] split = path.split("/");

        for(String s: split)
        {

            if(s.equals("") || s.equals("."))
            {
             continue;
            }
            else if( s.equals(".."))
            {
                if(!stack.isEmpty())
                {
                stack.pop();
                }

            }
            else stack.push(s);

        }



        StringBuilder sb = new StringBuilder();
       
        for(String s : stack)
        {
            sb.append("/");
            sb.append(s);
        }


        return sb.length() == 0 ? "/" : sb.toString();
        
    }
}
